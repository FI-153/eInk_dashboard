# Copy this file to .env and fill in your values. The .env file is gitignored.
# .env is used ONLY for local development via `make run`. Docker and other
# deployments pass these as real environment variables (see docker-compose.yml).

# Home Assistant connection
HASS_IP=
HASS_PORT=
HASS_TOKEN=

# How often the page auto-refreshes (seconds)
PAGE_REFRESH_INTERVAL_SECONDS=60
CSS_STYLESHEET_PATH=./static/css/styles.css

# Sensor / entity IDs
WEATHER_SENSOR_ID=
WEATHER_CITY_NAME=
ETA_TO_WORK_SENSOR_ID=
PUBLIC_IP_SENSOR_ID=
DOWNLOAD_SPD_SENSOR_ID=
UPLOAD_SPD_SENSOR_ID=
LAN_DOWNLOAD_SPD_SENSOR_ID=
LAN_UPLOAD_SPD_SENSOR_ID=

# Comma-separated "entity_id:label" pairs shown in the "@home" section
# e.g. PERSON_TRACKERS=person.alice:A,person.bob:B
PERSON_TRACKERS=
